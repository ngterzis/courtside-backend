ENV=local

JWT_SECRET=dev-only-jwt-secret-replace-in-prod-32-plus-bytes
JWT_EXPIRY_MINUTES=10080

# Local dev: direct Postgres connection (defaults match docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=courtside
DB_USER=courtside
DB_PASSWORD=courtside

# Production (Lambda) — set by Terraform, not needed locally:
# USE_DATA_API=true
# DB_CLUSTER_ARN=
# DB_SECRET_ARN=
# AWS_REGION=eu-central-1

# Direct connection via a full SQLAlchemy URL (wins over the DB_* fields above).
# Used by the Fargate migration task; handy for pointing local dev at a remote DB.
# DATABASE_URL=postgresql+psycopg://courtside:courtside@localhost:5432/courtside

ANTHROPIC_API_KEY=
